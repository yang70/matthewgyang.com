---

---

<section class="hero-gradient relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Floating particles -->
  <div class="absolute inset-0">
    <div class="particle w-2 h-2 bg-electric/30 top-[20%] left-[10%]" style="animation-duration: 6s; animation-delay: 0s;"></div>
    <div class="particle w-1 h-1 bg-purple/40 top-[60%] left-[80%]" style="animation-duration: 8s; animation-delay: 1s;"></div>
    <div class="particle w-3 h-3 bg-coral/20 top-[30%] left-[70%]" style="animation-duration: 10s; animation-delay: 2s;"></div>
    <div class="particle w-1.5 h-1.5 bg-mint/30 top-[80%] left-[20%]" style="animation-duration: 7s; animation-delay: 3s;"></div>
    <div class="particle w-2 h-2 bg-electric/20 top-[10%] left-[50%]" style="animation-duration: 9s; animation-delay: 1.5s;"></div>
    <div class="particle w-1 h-1 bg-purple/30 top-[50%] left-[40%]" style="animation-duration: 11s; animation-delay: 4s;"></div>
    <div class="particle w-2.5 h-2.5 bg-coral/15 top-[70%] left-[60%]" style="animation-duration: 12s; animation-delay: 0.5s;"></div>
    <div class="particle w-1 h-1 bg-mint/20 top-[40%] left-[90%]" style="animation-duration: 8s; animation-delay: 2.5s;"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.07]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Mesh gradient -->
  <div class="absolute top-[20%] left-[15%] w-[600px] h-[600px] rounded-full bg-electric/[0.15] blur-[130px]"></div>
  <div class="absolute bottom-[10%] right-[10%] w-[500px] h-[500px] rounded-full bg-purple/[0.18] blur-[120px]"></div>
  <div class="absolute top-[60%] left-[50%] w-[450px] h-[450px] rounded-full bg-coral/[0.12] blur-[110px]"></div>

  <!-- Noise/grain texture -->
  <div class="absolute inset-0 opacity-[0.08]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;"></div>

  <!-- Vignette -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.55) 100%);"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold mb-6 leading-tight">
      <span class="bg-gradient-to-r from-electric via-purple to-coral bg-clip-text text-transparent">
        Matthew Yang
      </span><span class="cursor"></span>
    </h1>

    <p class="text-lg sm:text-xl text-white/80 font-semibold tracking-wide uppercase mb-4">Backend Software Engineer</p>

    <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Building robust payment systems, scaling applications, and crafting reliable backend architectures with
      <span class="text-electric">Ruby</span>, <span class="text-purple">C#</span>, and modern cloud infrastructure.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#contact"
        class="btn-glow px-8 py-3 rounded-lg bg-electric text-white font-semibold text-base hover:bg-electric-light transition-colors"
      >
        Get In Touch
      </a>
      <a
        href="#experience"
        class="px-8 py-3 rounded-lg border border-white/20 text-white font-semibold text-base hover:border-electric/50 hover:text-electric transition-colors"
      >
        View My Work
      </a>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
