---

---

<section id="education" class="py-24 px-4 bg-navy-800/30">
  <div class="max-w-4xl mx-auto">
    <div class="reveal mb-16">
      <span class="font-mono text-sm text-electric">// education</span>
      <h2 class="font-display text-4xl font-bold text-white mt-2">
        Education
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-electric to-purple mt-4 rounded"></div>
    </div>

    <div class="reveal">
      <div class="p-8 rounded-2xl bg-navy-800/50 border border-purple/20 backdrop-blur-sm relative overflow-hidden">
        <!-- Decorative UW purple accent -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-purple/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>

        <div class="flex flex-col sm:flex-row items-start gap-6">
          <!-- UW Icon -->
          <div class="w-16 h-16 rounded-xl bg-purple/10 border border-purple/20 flex items-center justify-center shrink-0">
            <span class="font-display text-2xl font-bold text-purple">UW</span>
          </div>

          <div>
            <h3 class="font-display text-2xl font-bold text-white mb-1">
              University of Washington
            </h3>
            <p class="text-slate-400 mb-4">Seattle, Washington</p>

            <div class="space-y-2">
              <div class="flex items-center gap-3">
                <span class="text-purple font-mono text-sm">degree:</span>
                <span class="text-slate-300">Bachelor of Arts in Society & Justice</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-purple font-mono text-sm">minor:</span>
                <span class="text-slate-300">Political Science</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-purple font-mono text-sm">year:</span>
                <span class="text-slate-300">2003</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="reveal mt-8">
      <div class="p-8 rounded-2xl bg-navy-800/50 border border-electric/20 backdrop-blur-sm relative overflow-hidden">
        <!-- Decorative accent -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-electric/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>

        <div class="flex flex-col sm:flex-row items-start gap-6">
          <!-- CF Icon -->
          <div class="w-16 h-16 rounded-xl bg-electric/10 border border-electric/20 flex items-center justify-center shrink-0">
            <span class="font-display text-2xl font-bold text-electric">CF</span>
          </div>

          <div>
            <h3 class="font-display text-2xl font-bold text-white mb-1">
              Code Fellows
            </h3>
            <p class="text-slate-400 mb-4">Seattle, Washington</p>

            <div class="space-y-2">
              <div class="flex items-center gap-3">
                <span class="text-electric font-mono text-sm">focus:</span>
                <span class="text-slate-300">Ruby on Rails Development</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-electric font-mono text-sm">year:</span>
                <span class="text-slate-300">2015</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
