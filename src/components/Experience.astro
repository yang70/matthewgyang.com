---
const experiences = [
  {
    company: 'Apartments.com',
    role: 'Senior Software Engineer, Payments Team',
    period: '2019 — Present',
    location: 'Portland, OR',
    color: 'electric',
    highlights: [
      'Assisted in migrating thousands of users from Cozy.co to the Apartments.com platform',
      'Migrated a complete and mature Ruby application to C# / .NET',
      'Extensive integration with the Stripe payment processing platform, including Stripe Connect',
      'Worked on large-scale payment infrastructure serving a major real estate platform',
    ],
  },
  {
    company: 'Cozy.co',
    role: 'Senior Software Engineer',
    period: '2019',
    location: 'Portland, OR',
    color: 'purple',
    highlights: [
      'Full-stack development with Ruby and JavaScript',
      'Built and maintained features for a property management and payments platform',
      'Worked with PostgreSQL and integrated third-party payment services',
    ],
  },
  {
    company: 'Sportsrocket',
    role: 'Software Engineer / Technical Team Lead',
    period: '2016 — 2019',
    location: 'Bellevue, WA',
    color: 'coral',
    highlights: [
      'Full-stack development with Ruby on Rails and Angular for a sports streaming platform',
      'Gained foundational experience in professional software development',
    ],
  },
];

const priorCareer = [
  {
    role: 'Corrections Officer',
    org: 'City Jail',
    duration: '7 years',
    icon: '🔒',
  },
  {
    role: '911 Police Dispatcher',
    org: 'Emergency Services',
    duration: '4 years',
    icon: '📡',
  },
];

const colorMap: Record<string, { dot: string; border: string; text: string }> = {
  electric: { dot: 'bg-electric', border: 'border-electric/30', text: 'text-electric' },
  purple: { dot: 'bg-purple', border: 'border-purple/30', text: 'text-purple' },
  coral: { dot: 'bg-coral', border: 'border-coral/30', text: 'text-coral' },
};
---

<section id="experience" class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="reveal mb-16">
      <span class="font-mono text-sm text-electric">// experience</span>
      <h2 class="font-display text-4xl font-bold text-white mt-2">
        Where I've Worked
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-electric to-purple mt-4 rounded"></div>
    </div>

    <!-- Software Engineering Timeline -->
    <div class="relative pl-10 space-y-12 mb-16">
      <div class="timeline-line"></div>

      {experiences.map((exp, i) => {
        const colors = colorMap[exp.color];
        return (
          <div class="reveal relative" style={`transition-delay: ${i * 150}ms;`}>
            <!-- Timeline dot -->
            <div class={`absolute -left-10 top-1 w-4 h-4 rounded-full ${colors.dot} border-4 border-navy-900 z-10`}></div>

            <div class={`p-6 rounded-xl bg-navy-800/50 border ${colors.border} backdrop-blur-sm`}>
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3">
                <h3 class="font-display text-xl font-bold text-white">{exp.company}</h3>
                <span class="font-mono text-xs text-slate-500 mt-1 sm:mt-0">{exp.period}</span>
              </div>
              <p class={`text-sm font-medium ${colors.text} mb-1`}>{exp.role}</p>
              {exp.location && <p class="text-xs text-slate-500 mb-4">{exp.location}</p>}
              <ul class="space-y-2">
                {exp.highlights.map((highlight) => (
                  <li class="flex items-start gap-3 text-slate-300 text-sm leading-relaxed">
                    <span class={`mt-1.5 w-1.5 h-1.5 rounded-full ${colors.dot} shrink-0`}></span>
                    {highlight}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Prior Career -->
    <div class="reveal">
      <h3 class="font-display text-xl font-semibold text-white mb-6 flex items-center gap-3">
        <span class="w-8 h-[1px] bg-slate-600"></span>
        Prior Career
        <span class="w-8 h-[1px] bg-slate-600"></span>
      </h3>
      <div class="grid sm:grid-cols-2 gap-4">
        {priorCareer.map((job) => (
          <div class="p-5 rounded-xl bg-navy-800/30 border border-white/5 hover:border-white/10 transition-colors">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">{job.icon}</span>
              <div>
                <h4 class="font-semibold text-white">{job.role}</h4>
                <p class="text-sm text-slate-400">{job.org} &middot; {job.duration}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
