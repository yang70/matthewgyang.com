---

---

<section id="contact" class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="reveal mb-16 text-center">
      <span class="font-mono text-sm text-electric">// contact</span>
      <h2 class="font-display text-4xl font-bold text-white mt-2">
        Get In Touch
      </h2>
      <p class="text-slate-400 mt-4 max-w-lg mx-auto">
        Interested in working together or have a question? Send me a message and I'll get back to you.
      </p>
      <div class="w-20 h-1 bg-gradient-to-r from-electric to-purple mt-6 rounded mx-auto"></div>
    </div>

    <div class="grid md:grid-cols-5 gap-12">
      <!-- Contact Form -->
      <div class="md:col-span-3 reveal-left">
        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label for="name" class="block text-sm font-medium text-slate-300 mb-2">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg bg-navy-800/50 border border-white/10 text-white placeholder-slate-500 focus:border-electric focus:ring-1 focus:ring-electric focus:outline-none transition-colors"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg bg-navy-800/50 border border-white/10 text-white placeholder-slate-500 focus:border-electric focus:ring-1 focus:ring-electric focus:outline-none transition-colors"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-slate-300 mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg bg-navy-800/50 border border-white/10 text-white placeholder-slate-500 focus:border-electric focus:ring-1 focus:ring-electric focus:outline-none transition-colors resize-none"
              placeholder="Your message..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-glow w-full px-8 py-3 rounded-lg bg-electric text-white font-semibold text-base hover:bg-electric-light transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Links -->
      <div class="md:col-span-2 reveal-right">
        <div class="space-y-6">
          <div class="p-5 rounded-xl bg-navy-800/50 border border-white/5">
            <h3 class="font-display font-semibold text-white mb-4">Connect</h3>
            <div class="space-y-4">
              <!-- GitHub -->
              <a
                href="https://github.com/yang70"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-slate-300 hover:text-electric transition-colors group"
              >
                <div class="w-10 h-10 rounded-lg bg-navy-700 border border-white/10 flex items-center justify-center group-hover:border-electric/30 transition-colors">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-medium">GitHub</div>
                  <div class="text-xs text-slate-500">yang70</div>
                </div>
              </a>

              <!-- LinkedIn -->
              <a
                href="https://www.linkedin.com/in/matthewgyang/"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-slate-300 hover:text-electric transition-colors group"
              >
                <div class="w-10 h-10 rounded-lg bg-navy-700 border border-white/10 flex items-center justify-center group-hover:border-electric/30 transition-colors">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-medium">LinkedIn</div>
                  <div class="text-xs text-slate-500">matthewgyang</div>
                </div>
              </a>
            </div>
          </div>

          <div class="p-5 rounded-xl bg-navy-800/50 border border-white/5">
            <h3 class="font-display font-semibold text-white mb-2">Location</h3>
            <p class="text-slate-400 text-sm">Camas, Washington</p>
            <p class="text-slate-500 text-xs mt-1">Pacific Time Zone (PT)</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
